{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenySpecificUserAll",
      "Effect": "Deny",
      "Principal": {
        "AWS": [
          "arn:aws:iam::<aws-account-id>:user/<iam-username>"
        ]
      },
      "Action": [
        "s3:*"
      ],
      "Resource": "arn:aws:s3:::<your-bucket-name>/*"
    }
  ]
}
