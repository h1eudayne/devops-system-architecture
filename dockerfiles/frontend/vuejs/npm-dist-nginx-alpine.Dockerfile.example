## build stage ##
FROM node:18.18-alpine AS build

WORKDIR /app
COPY . .
RUN npm install
RUN npm run build

## run stage ##
FROM nginx:alpine

# Neu project build ra thu muc khac `dist`, hay doi duong dan ben duoi.
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
