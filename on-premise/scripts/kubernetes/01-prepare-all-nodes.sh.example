#!/bin/bash

# ==============================================================================
# 01-prepare-all-nodes.sh
# Chuan bi tat ca cac node cho cum Kubernetes on-premise (Ubuntu 22.04)
# Chay script nay tren TAT CA cac server (master va worker)
# Yeu cau: user co quyen sudo
# ==============================================================================

set -euo pipefail

# ------------------------------------------------------------------------------
# Bien cau hinh - thay doi cho phu hop voi moi truong
# ------------------------------------------------------------------------------
KUBE_VERSION="v1.30"
KUBE_APT_REPO="https://pkgs.k8s.io/core:/stable:/${KUBE_VERSION}/deb/"

# Danh sach IP va hostname - thay doi neu IP khac
HOSTS_ENTRIES=(
    "192.168.1.111 k8s-master-1"
    "192.168.1.112 k8s-master-2"
    "192.168.1.113 k8s-master-3"
)

# ==============================================================================
# Buoc 1: Them hosts
# ==============================================================================
echo ">>> [1/10] Cau hinh /etc/hosts ..."
for entry in "${HOSTS_ENTRIES[@]}"; do
    if ! grep -q "$entry" /etc/hosts; then
        echo "$entry" | sudo tee -a /etc/hosts
    fi
done

# ==============================================================================
# Buoc 2: Cap nhat va nang cap he thong
# ==============================================================================
echo ">>> [2/10] Cap nhat va nang cap he thong ..."
sudo apt update -y && sudo apt upgrade -y

# ==============================================================================
# Buoc 3: Tao user devops va cap quyen sudo
# ==============================================================================
echo ">>> [3/10] Tao user devops ..."
if ! id "devops" &>/dev/null; then
    sudo adduser --gecos "" devops
    sudo usermod -aG sudo devops
    echo "  User devops da duoc tao va them vao nhom sudo."
    echo "  Sau khi script chay xong, chuyen sang user devops:"
    echo "    su devops"
    echo "    cd /home/devops"
else
    echo "  User devops da ton tai, bo qua."
fi

# ==============================================================================
# Buoc 4: Tat swap
# ==============================================================================
echo ">>> [4/10] Tat swap ..."
sudo swapoff -a
sudo sed -i '/swap.img/s/^/#/' /etc/fstab

# ==============================================================================
# Buoc 5: Cau hinh kernel module
# ==============================================================================
echo ">>> [5/10] Cau hinh kernel module ..."
cat <<EOF | sudo tee /etc/modules-load.d/containerd.conf
overlay
br_netfilter
EOF

sudo modprobe overlay
sudo modprobe br_netfilter

# ==============================================================================
# Buoc 6: Cau hinh sysctl cho mang
# ==============================================================================
echo ">>> [6/10] Cau hinh sysctl ..."
cat <<EOF | sudo tee /etc/sysctl.d/kubernetes.conf
net.bridge.bridge-nf-call-ip6tables = 1
net.bridge.bridge-nf-call-iptables = 1
net.ipv4.ip_forward = 1
EOF

sudo sysctl --system

# ==============================================================================
# Buoc 7: Cai dat cac goi can thiet va them kho Docker
# ==============================================================================
echo ">>> [7/10] Cai dat cac goi can thiet ..."
sudo apt install -y curl gnupg2 software-properties-common apt-transport-https ca-certificates

sudo curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmour -o /etc/apt/trusted.gpg.d/docker.gpg
sudo add-apt-repository -y "deb [arch=amd64] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable"

# ==============================================================================
# Buoc 8: Cai dat va cau hinh containerd
# ==============================================================================
echo ">>> [8/10] Cai dat containerd ..."
sudo apt update -y
sudo apt install -y containerd.io

containerd config default | sudo tee /etc/containerd/config.toml >/dev/null 2>&1
sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/g' /etc/containerd/config.toml

sudo systemctl restart containerd
sudo systemctl enable containerd

# ==============================================================================
# Buoc 9: Them kho luu tru Kubernetes
# ==============================================================================
echo ">>> [9/10] Them kho luu tru Kubernetes ..."
sudo mkdir -p /etc/apt/keyrings
echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] ${KUBE_APT_REPO} /" | sudo tee /etc/apt/sources.list.d/kubernetes.list
curl -fsSL "${KUBE_APT_REPO}Release.key" | sudo gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg

# ==============================================================================
# Buoc 10: Cai dat kubelet, kubeadm, kubectl
# ==============================================================================
echo ">>> [10/10] Cai dat kubelet, kubeadm, kubectl ..."
sudo apt update -y
sudo apt install -y kubelet kubeadm kubectl
sudo apt-mark hold kubelet kubeadm kubectl

echo ""
echo "==========================================================================="
echo "  HOAN TAT chuan bi node!"
echo ""
echo "  Chuyen sang user devops truoc khi tiep tuc:"
echo "    su devops"
echo "    cd /home/devops"
echo ""
echo "  Tiep theo:"
echo "    - Mo hinh 1 master + 2 worker: chay 02-init-single-master.sh tren master-1"
echo "    - Mo hinh 3 master HA:         chay 03-init-ha-master.sh tren master-1"
echo "==========================================================================="
