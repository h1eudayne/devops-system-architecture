# =============================================================================
# Template: Kubernetes Service for MariaDB (ClusterIP & NodePort Options)
# -----------------------------------------------------------------------------
# Lưu ý quan trọng:
#   - Tên Service bắt buộc phải là: mariadb-service (khớp với serviceName cấu hình trong StatefulSet).
#   - Hướng dẫn này cung cấp 2 CÁCH CẤU HÌNH tương ứng với 2 nhu cầu khác nhau.
#
# CÁCH 1: ClusterIP (KHUYẾN NGHỊ CHO PRODUCTION)
#   - Chỉ cho phép truy cập nội bộ trong cụm K8s. Các ứng dụng khác (như Backend)
#     sẽ kết nối tới MariaDB an toàn qua DNS nội bộ: mariadb-service.ecommerce.svc.cluster.local
#   - Đây là mô hình bảo mật chuẩn, tránh để lộ Database ra môi trường bên ngoài.
#
# CÁCH 2: NodePort (PHÙ HỢP CHO LIÊN KẾT NGOÀI & TEST)
#   - Mở cổng vật lý 31306 trên tất cả các node trong cụm Kubernetes.
#   - Giúp DevOps/Developer kết nối trực tiếp đến Database bằng các công cụ bên ngoài
#     (DBeaver, Navicat, CLI) thông qua <NODE_IP>:31306.
# =============================================================================

# -----------------------------------------------------------------------------
# CẤU HÌNH CÁCH 1: ClusterIP (Mặc định hoạt động)
# -----------------------------------------------------------------------------
apiVersion: v1
kind: Service
metadata:
  name: mariadb-service
  namespace: ecommerce
spec:
  selector:
    app: mariadb # Ánh xạ tới Pod MariaDB của StatefulSet
  type: ClusterIP # Chỉ truy cập nội bộ
  ports:
    - port: 3306      # Cổng của Service
      targetPort: 3306 # Cổng của container MariaDB

# -----------------------------------------------------------------------------
# CẤU HÌNH CÁCH 2: NodePort (Nếu muốn dùng, hãy BỎ COMMENT khối dưới và XÓA khối trên)
# -----------------------------------------------------------------------------
# apiVersion: v1
# kind: Service
# metadata:
#   name: mariadb-service
#   namespace: ecommerce
# spec:
#   selector:
#     app: mariadb
#   type: NodePort # Cho phép truy cập từ ngoài qua IP Node
#   ports:
#     - port: 3306
#       targetPort: 3306
#       nodePort: 31306 # Cổng vật lý trên mỗi node (phải trong dải 30000-32767)

