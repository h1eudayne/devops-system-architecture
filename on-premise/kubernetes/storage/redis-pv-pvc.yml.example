# =============================================================================
# Template: Kubernetes PV & PVC configuration for Redis (NFS Storage)
# -----------------------------------------------------------------------------
# Lưu ý quan trọng:
#   - PersistentVolume (PV) là TÀI NGUYÊN TOÀN CỤC (Cluster-scoped resource),
#     không thuộc về bất kỳ namespace nào (không cấu hình metadata.namespace).
#   - PersistentVolumeClaim (PVC) là TÀI NGUYÊN CỤC BỘ (Namespace-scoped resource).
#     Nó bắt buộc phải nằm chung namespace với Pod sử dụng nó (ở đây là namespace: architecture).
#   - Đây là giải pháp cho môi trường ON-PREMISE sử dụng cơ chế thủ công:
#     Bạn bắt buộc phải tạo thư mục vật lý '/data/redis/' trên NFS Server và cấp quyền ghi 
#     cho user (no_root_squash, chmod 777) trước khi deploy.
#
# Hướng dẫn sử dụng:
#   1. Sao chép file này và đổi tên bỏ đuôi .example:
#        cp redis-pv-pvc.yml.example redis-pv-pvc.yml
#   2. Cập nhật địa chỉ IP của NFS Server tại trường spec.nfs.server (mặc định: 192.168.1.115).
#   3. Áp dụng cấu hình:
#        kubectl apply -f redis-pv-pvc.yml
#   4. Kiểm tra trạng thái:
#        kubectl get pv redis-pv
#        kubectl get pvc redis-pvc -n architecture
# =============================================================================

apiVersion: v1
kind: PersistentVolume
metadata:
  name: redis-pv
spec:
  capacity:
    storage: 10Gi
  accessModes:
    - ReadWriteMany
  nfs:
    path: /data/redis/
    server: 192.168.1.115 # Chú ý thay địa chỉ IP tương ứng của bạn
  persistentVolumeReclaimPolicy: Retain
  storageClassName: nfs-storage
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: redis-pvc
  namespace: architecture
spec:
  accessModes:
    - ReadWriteMany
  resources:
    requests:
      storage: 10Gi
  storageClassName: nfs-storage
